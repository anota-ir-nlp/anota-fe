# Production environment variables
# Copy this to .env and update the values for your deployment

# Authentication
AUTH_ORIGIN=http://localhost:3000
AUTH_SECRET=your-secret-key-here

# API Configuration
NUXT_PUBLIC_API_BASE_URL=/api/proxy
NUXT_BACKEND_URL=https://anota.cs.ui.ac.id/server/api/v1/

# Node Environment
NODE_ENV=production

# Server Configuration
HOST=0.0.0.0
PORT=3030

# Optional: If you need database or other service URLs
# DATABASE_URL=postgresql://user:pass@localhost:5432/anota
# REDIS_URL=redis://localhost:6379
